# Bazel build options for quant_invest

# C++20 standard
build --cxxopt=-std=c++20
build --conlyopt=-std=c2x

# Compiler warnings (Google C++ Style)
build --cxxopt=-Wall
build --cxxopt=-Wextra
build --cxxopt=-Werror
build --cxxopt=-Wpedantic
build --cxxopt=-Wno-unused-parameter
build --cxxopt=-Wno-missing-field-initializers

# Optimization for release builds
build:release -c opt

# Debug builds with sanitizers
build:debug -c dbg
build:asan --cxxopt=-fsanitize=address --linkopt=-fsanitize=address
build:tsan --cxxopt=-fsanitize=thread --linkopt=-fsanitize=thread

# Test output
test --test_output=errors